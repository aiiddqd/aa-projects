---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout
	title="Ads Art Group | Промышленный арт-брендинг"
	description="Промышленное брендирование в художественном стиле: кейсы, услуги, процесс и прямые контакты без форм."
>
	<header class="top-nav">
		<a class="top-nav-brand" href="#hero">Ads Art Group</a>
		<nav class="top-nav-menu ml-auto">
			<a class="top-nav-link" href="#services">Услуги</a>
			<a class="top-nav-link" href="#projects">Проекты</a>
			<a class="top-nav-link" href="#process">Процесс</a>
			<a class="top-nav-link" href="#team">Команда</a>
			<a class="top-nav-link" href="#contacts">Контакты</a>
		</nav>
		<div class="ml-auto flex items-center gap-2 lg:ml-8">
			<label class="theme-toggle flex cursor-pointer items-center gap-2" aria-label="Переключить тему" title="Переключить тему">
				<svg class="icon-sun" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
					<circle cx="12" cy="12" r="5" />
					<path d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" />
				</svg>
				<input type="checkbox" id="theme-checkbox" class="toggle" />
				<svg class="icon-moon" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
				</svg>
			</label>
			<a class="btn-primary" href="#contacts">Запустить проект</a>
		</div>
	</header>

	<main>
		<!-- ─────────────── Hero — hero-band-cinema ─────────────── -->
		<section class="hero-band-cinema" id="hero">
			<img
				src="https://images.unsplash.com/photo-1581094794329-c8112a89af12?auto=format&fit=crop&w=2000&q=80"
				alt="Промышленный объект — резервуарный парк"
				loading="eager"
			/>
			<div class="hero-band-cinema-content">
				<span class="caption-uppercase section-label">Паспорт объекта / промышленный арт-брендинг</span>
				<h1 class="display-mega">
					Брендинг промышленных поверхностей, который видно до въезда на объект
				</h1>
				<p class="body-md mt-6 max-w-2xl" style="color: var(--body);">
					Превращаем контейнеры, резервуары, фасады и спецтехнику в арт-носители бренда.
					Маршрут проекта прозрачен: бриф, превиз, нанесение, сдача и сопровождение.
				</p>
				<div class="hero-cta-row">
					<a class="btn-primary" href="#contacts">Обсудить проект</a>
					<a class="btn-outline" href="#projects">Смотреть кейсы</a>
				</div>
			</div>
		</section>

		<!-- ─────────────── Services ─────────────── -->
		<section class="section-band" id="services">
			<div class="section-container">
				<span class="caption-uppercase section-label">Услуги</span>
				<h2 class="display-lg">Полный цикл — от идеи до сопровождения</h2>
				<p class="body-md mt-3 max-w-2xl">От превизуализации до покраски и сопровождения на объекте.</p>
				<div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
					<article class="feature-card-photo">
						<img
							class="feature-card-photo-image"
							src="https://images.unsplash.com/photo-1565043666747-69feca4a9130?auto=format&fit=crop&w=800&q=70"
							alt="Промышленное брендирование"
							loading="lazy"
						/>
						<div class="feature-card-photo-body">
							<h3><Icon class="mr-2" name="industrial" />Промышленное брендирование</h3>
							<p>Краски и эмали для сложных поверхностей и экстремальных условий.</p>
							<p class="caption mt-2">Поверхности: металл, бетон, композит · Условия: ветер, пыль, перепады температур</p>
						</div>
					</article>
					<article class="feature-card-photo">
						<img
							class="feature-card-photo-image"
							src="https://images.unsplash.com/photo-1518709268805-4e9042af9f23?auto=format&fit=crop&w=800&q=70"
							alt="Крупноформатная графика"
							loading="lazy"
						/>
						<div class="feature-card-photo-body">
							<h3><Icon class="mr-2" name="art" />Крупноформатная графика</h3>
							<p>Суперграфика на резервуарах, фасадах и технологических зонах.</p>
							<p class="caption mt-2">Масштаб: от 200 до 12 000 м² · Этап: эскиз, превиз, нанесение</p>
						</div>
					</article>
					<article class="feature-card-photo">
						<img
							class="feature-card-photo-image"
							src="https://images.unsplash.com/photo-1494412651409-896322b269f6?auto=format&fit=crop&w=800&q=70"
							alt="Арт-навигация и маркировка"
							loading="lazy"
						/>
						<div class="feature-card-photo-body">
							<h3><Icon class="mr-2" name="route" />Арт-навигация и маркировка</h3>
							<p>Маршруты, зоны безопасности и визуальная навигация без визуального шума.</p>
							<p class="caption mt-2">Сценарий: маршруты, риск-зоны, KPI-указатели · Формат: модульная система кодов</p>
						</div>
					</article>
					<article class="feature-card-photo">
						<img
							class="feature-card-photo-image"
							src="https://images.unsplash.com/photo-1601584115197-04ecc0da31d7?auto=format&fit=crop&w=800&q=70"
							alt="Спецтехника и транспорт"
							loading="lazy"
						/>
						<div class="feature-card-photo-body">
							<h3><Icon class="mr-2" name="truck" />Спецтехника и транспорт</h3>
							<p>Брендинг транспорта под интенсивную эксплуатацию и регулярные мойки.</p>
							<p class="caption mt-2">Поток: ночные смены без простоя · Устойчивость: мойки, реагенты, абразив</p>
						</div>
					</article>
					<article class="feature-card-photo">
						<img
							class="feature-card-photo-image"
							src="https://images.unsplash.com/photo-1581092160562-40aa08e29829?auto=format&fit=crop&w=800&q=70"
							alt="3D-превизуализация"
							loading="lazy"
						/>
						<div class="feature-card-photo-body">
							<h3><Icon class="mr-2" name="lab" />3D-превизуализация</h3>
							<p>Согласование визуала на цифровой модели объекта до выхода в поле.</p>
							<p class="caption mt-2">Проверка: масштаб, читаемость, ракурсы · Выход: согласованный рабочий макет</p>
						</div>
					</article>
					<article class="feature-card-photo">
						<img
							class="feature-card-photo-image"
							src="https://images.unsplash.com/photo-1504917595217-d4dc8b668f47?auto=format&fit=crop&w=800&q=70"
							alt="Сопровождение площадок"
							loading="lazy"
						/>
						<div class="feature-card-photo-body">
							<h3><Icon class="mr-2" name="time" />Сопровождение площадок</h3>
							<p>Обновление графики, поддержка фирменной системы и сезонные кампании.</p>
							<p class="caption mt-2">Регламент: инспекция и refresh-слой · Результат: единый визуальный стандарт</p>
						</div>
					</article>
				</div>
			</div>
		</section>

		<!-- ─────────────── Livery band — Rosso Corsa accent ─────────────── -->
		<section class="livery-band">
			<div class="section-container">
				<p class="caption-uppercase" style="color: var(--on-primary); opacity: 0.8;">Масштаб</p>
				<h2 class="display-lg mt-2">12 500 м² за 28 дней — без остановки производства</h2>
			</div>
		</section>

		<!-- ─────────────── Projects ─────────────── -->
		<section class="section-band" id="projects">
			<div class="section-container">
				<span class="caption-uppercase section-label">Проекты</span>
				<h2 class="display-lg">Кейсы</h2>
				<div class="mt-8 grid gap-5 lg:grid-cols-3">
					<article class="feature-card-photo">
						<img
							class="feature-card-photo-image"
							src="https://images.unsplash.com/photo-1565043666747-69feca4a9130?auto=format&fit=crop&w=800&q=70"
							alt="Резервуарный парк"
							loading="lazy"
						/>
						<div class="feature-card-photo-body">
							<span class="badge-pill mb-3"><Icon name="industrial" size="sm" />Резервуарный парк</span>
							<h3>Контекст</h3>
							<p>Сделать объект заметным с магистрали и повысить узнаваемость бренда в регионе.</p>
							<h3 class="mt-4">Решение</h3>
							<p>Суперграфика на 4 резервуарах и фасаде операторной с ночной подсветкой.</p>
							<h3 class="mt-4">Результат</h3>
							<p>12 500 м² за 28 дней, запуск без остановки производственного цикла.</p>
						</div>
					</article>
					<article class="feature-card-photo">
						<img
							class="feature-card-photo-image"
							src="https://images.unsplash.com/photo-1494412651409-896322b269f6?auto=format&fit=crop&w=800&q=70"
							alt="Контейнерный терминал"
							loading="lazy"
						/>
						<div class="feature-card-photo-body">
							<span class="badge-pill mb-3"><Icon name="route" size="sm" />Контейнерный терминал</span>
							<h3>Контекст</h3>
							<p>Унифицировать визуальный код 400+ контейнеров и навигацию по площадке.</p>
							<h3 class="mt-4">Решение</h3>
							<p>Модульная система маркировки, цветовые зоны и ускоренный цикл нанесения.</p>
							<h3 class="mt-4">Результат</h3>
							<p>Сроки погрузки сократились на 14%, снизилось число операционных ошибок.</p>
						</div>
					</article>
					<article class="feature-card-photo">
						<img
							class="feature-card-photo-image"
							src="https://images.unsplash.com/photo-1601584115197-04ecc0da31d7?auto=format&fit=crop&w=800&q=70"
							alt="Спецтранспорт"
							loading="lazy"
						/>
						<div class="feature-card-photo-body">
							<span class="badge-pill mb-3"><Icon name="truck" size="sm" />Спецтранспорт</span>
							<h3>Контекст</h3>
							<p>Обновить флот из 60 единиц без вывода техники из графика.</p>
							<h3 class="mt-4">Решение</h3>
							<p>Поточный бренд-пакет с ночными сменами и шаблонами для повторяемости.</p>
							<h3 class="mt-4">Результат</h3>
							<p>Проект завершен за 21 день, фирменный стиль выровнен на всем автопарке.</p>
						</div>
					</article>
				</div>
			</div>
		</section>

		<!-- ─────────────── Process ─────────────── -->
		<section class="section-band" id="process">
			<div class="section-container">
				<span class="caption-uppercase section-label">Процесс</span>
				<h2 class="display-lg">Дорожная карта</h2>
				<ol class="process-rail mt-8">
					<li class="process-step">
						<p class="process-label"><Icon name="lab" size="sm" />Этап 01</p>
						<h3 class="title-md">Бриф и аудит объекта</h3>
						<p class="body-md mt-2">Фиксируем задачи площадки, ограничения по режиму работ и целевые метрики узнаваемости.</p>
					</li>
					<li class="process-step">
						<p class="process-label"><Icon name="art" size="sm" />Этап 02</p>
						<h3 class="title-md">Концепт и превиз</h3>
						<p class="body-md mt-2">Показываем визуал на модели объекта и подтверждаем читаемость в реальном масштабе.</p>
					</li>
					<li class="process-step">
						<p class="process-label"><Icon name="industrial" size="sm" />Этап 03</p>
						<h3 class="title-md">Подготовка поверхности</h3>
						<p class="body-md mt-2">Прайминг, тесты материалов и логистика смен так, чтобы не вмешиваться в производственный цикл.</p>
					</li>
					<li class="process-step">
						<p class="process-label"><Icon name="time" size="sm" />Этап 04</p>
						<h3 class="title-md">Нанесение и контроль</h3>
						<p class="body-md mt-2">Работа по техкарте, контроль толщины слоя и промежуточная фотодокументация этапов.</p>
					</li>
					<li class="process-step">
						<p class="process-label"><Icon name="route" size="sm" />Этап 05</p>
						<h3 class="title-md">Сдача и сопровождение</h3>
						<p class="body-md mt-2">Передаем пакет фиксации результата и план обновления графики на сезонные кампании.</p>
					</li>
				</ol>
			</div>
		</section>

		<!-- ─────────────── Team ─────────────── -->
		<section class="section-band" id="team">
			<div class="section-container">
				<span class="caption-uppercase section-label">Команда</span>
				<h2 class="display-lg">Кто работает на объекте</h2>
				<p class="body-md mt-3 max-w-3xl">Художники, технологи, промышленные альпинисты и проектные менеджеры, которые умеют работать в жестких производственных условиях.</p>
				<div class="mt-8 grid gap-4 md:grid-cols-4">
					<div class="role-tile">
						<Icon name="art" size="lg" />
						<p class="role-tile-name">Арт-директор</p>
					</div>
					<div class="role-tile">
						<Icon name="lab" size="lg" />
						<p class="role-tile-name">Технолог ЛКМ</p>
					</div>
					<div class="role-tile">
						<Icon name="industrial" size="lg" />
						<p class="role-tile-name">Промальп команда</p>
					</div>
					<div class="role-tile">
						<Icon name="time" size="lg" />
						<p class="role-tile-name">Проектный менеджмент</p>
					</div>
				</div>
			</div>
		</section>

		<!-- ─────────────── Contacts — cta-band-dark ─────────────── -->
		<section class="cta-band-dark" id="contacts">
			<div class="section-container">
				<span class="caption-uppercase section-label">Контакты</span>
				<h2 class="display-lg">Сразу к диалогу</h2>
				<p class="body-md mt-3 max-w-2xl mx-auto">
					Выбирайте удобный канал, мы подключимся к обсуждению задачи в рабочее окно.
				</p>
				<div class="mt-8 flex flex-wrap justify-center gap-3">
					<a class="btn-primary" data-track="cta_telegram" href="https://t.me/demo" rel="noreferrer" target="_blank">
						Обсудить — Telegram
					</a>
					<a class="btn-outline" data-track="cta_email" href="mailto:demo@example.com">
						Написать — почта
					</a>
					<a class="btn-outline" data-track="cta_phone" href="tel:+70000000000">
						Позвонить
					</a>
				</div>
				<p class="caption mt-6">Телефон: +7 000 000-00-00 · Демо-контакты: позже заменим на боевые.</p>
			</div>
		</section>
	</main>

	<footer class="footer-dark">
		<div class="section-container flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
			<p class="body-sm">© {new Date().getFullYear()} Ads Art Group</p>
			<div class="flex gap-4">
				<a data-track="footer_telegram" href="https://t.me/demo" rel="noreferrer" target="_blank">Telegram</a>
				<a data-track="footer_email" href="mailto:demo@example.com">Email</a>
				<a data-track="footer_phone" href="tel:+70000000000">Phone</a>
			</div>
		</div>
	</footer>

	<script>
		const sendMetric = (eventName) => {
			if (typeof window.gtag === 'function') {
				window.gtag('event', eventName);
			}

			window.dataLayer = window.dataLayer || [];
			window.dataLayer.push({ event: eventName });
		};

		document.querySelectorAll('[data-track]').forEach((node) => {
			node.addEventListener('click', () => {
				const eventName = node.getAttribute('data-track');
				if (eventName) {
					sendMetric(eventName);
				}
			});
		});

		// Theme toggle — switch between light and dark, persist to localStorage
		const themeCheckbox = document.getElementById('theme-checkbox');
		if (themeCheckbox) {
			// Sync checkbox with current data-theme (set by FOUC script)
			const current = document.documentElement.getAttribute('data-theme');
			themeCheckbox.checked = current === 'light';
			themeCheckbox.addEventListener('change', () => {
				const next = themeCheckbox.checked ? 'light' : 'dark';
				document.documentElement.setAttribute('data-theme', next);
				localStorage.setItem('theme', next);
			});
		}
	</script>
</Layout>
